1 drop table if exists z
1 set transaction read committed isolation
2 set transaction read committed isolation
1 create table z(i decimal128)
2 create procedure insert_itrs version 'v2' { local function main(itrs, start) for i=1,itrs do local result, rc = db:exec("insert into z values(start + i)"); end end }
2 exec procedure insert_itrs(11) 
1 begin
2 exec procedure insert_itrs(22)
1 select count(*) from z
1 commit
